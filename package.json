{
  "name": "fusionbrain",
  "version": "0.1.0",
  "private": true,
  "description": "Personal CNC/CAM/Fusion 360 knowledge assistant — RAG over curated YouTube transcripts, docs, and manuals.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build && cp -r public .next/standalone/public 2>/dev/null || true && cp -r .next/static .next/standalone/.next/static 2>/dev/null || true",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "next": "16.2.1",
    "pg": "^8.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
