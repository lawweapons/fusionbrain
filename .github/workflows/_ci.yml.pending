name: CI

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"

      - name: Install dependencies
        run: npm ci

      - name: Type check
        run: npm run typecheck

      - name: Lint
        run: npm run lint

      - name: Build
        run: npm run build
        env:
          # Stub env vars so build doesn't fail on missing secrets.
          # Real values live only on the VPS.
          DATABASE_URL: "postgresql://stub:stub@localhost:5432/stub"
          VOYAGE_API_KEY: "stub"
          ANTHROPIC_API_KEY: "stub"
          BASIC_AUTH_USER: "stub"
          BASIC_AUTH_PASS: "stub"
          INGEST_TOKEN: "stub"
