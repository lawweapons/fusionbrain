# Copy to .env on the VPS. NEVER commit the real values.

# Postgres (local to the VPS)
DATABASE_URL=postgresql://fusionbrain:CHANGEME_DB_PASSWORD@127.0.0.1:5432/fusionbrain_db

# Voyage AI embeddings (https://www.voyageai.com/)
VOYAGE_API_KEY=pa-CHANGEME

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-CHANGEME
ANSWER_MODEL=claude-sonnet-4-6

# HTTP Basic Auth (gates the web UI and /api/ask)
BASIC_AUTH_USER=robert
BASIC_AUTH_PASS=CHANGEME_32_CHAR_RANDOM

# Bearer token for /api/ingest (used by Python scripts only)
INGEST_TOKEN=CHANGEME_48_CHAR_RANDOM

# Next.js
PORT=3100
NODE_ENV=production
